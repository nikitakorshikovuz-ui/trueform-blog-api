<!-- 
  TRUEFORM: АВТОМАТИЧЕСКИЙ БЛОГ ИЗ ДЗЕНА (ДЛЯ TILDA T123)
  Связь с GitHub Actions настроена.
-->

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;900&display=swap" rel="stylesheet">

<style>
  /* === ИЗОЛЯЦИЯ СТИЛЕЙ TILDA === */
  .tf-blog-wrapper {
    background-color: #1A1A1A;
    color: #ffffff;
    font-family: 'Montserrat', sans-serif;
    min-height: 100vh;
    padding: 60px 20px;
    box-sizing: border-box;
    line-height: 1.5;
  }
  
  .tf-blog-wrapper * { box-sizing: border-box; }
  
  .tf-container {
    max-width: 1024px;
    margin: 0 auto;
    width: 100%;
  }

  /* === АНИМАЦИИ И ЭКРАНЫ === */
  .tf-view { display: none; animation: tfFadeIn 0.5s ease forwards; }
  .tf-view.is-active { display: block; }

  @keyframes tfFadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* === ЛЕНТА НОВОСТЕЙ (ШАПКА И ФИЛЬТРЫ) === */
  .tf-header { text-align: center; border-bottom: 1px solid #333; padding-bottom: 40px; margin-bottom: 40px; }
  .tf-header h1 { font-size: clamp(32px, 5vw, 48px); font-weight: 900; text-transform: uppercase; margin: 0 0 15px; color: #fff; }
  .tf-header h1 span { color: #B88655; }
  .tf-header p { color: #9ca3af; font-size: 18px; max-width: 700px; margin: 0 auto; line-height: 1.6; }

  .tf-filters {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 35px;
  }
  .tf-filter-btn {
    background: #1f1f1f; color: #9ca3af; border: 1px solid #333;
    padding: 12px 24px; border-radius: 50px; font-size: 13px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px; cursor: pointer;
    transition: all 0.3s ease; font-family: 'Montserrat', sans-serif;
  }
  .tf-filter-btn:hover { border-color: #B88655; color: #fff; }
  .tf-filter-btn.is-active {
    background: #B88655; color: #fff; border-color: #B88655;
    box-shadow: 0 0 15px rgba(184,134,85,0.4);
  }

  /* === КАРТОЧКА СТАТЬИ (ВЕРТИКАЛЬНАЯ ЛЕНТА) === */
  .tf-news-feed { display: flex; flex-direction: column; gap: 40px; }
  
  .tf-news-card {
    display: flex; flex-direction: column; background: #1f1f1f; border-radius: 20px;
    border: 1px solid #333; overflow: hidden; cursor: pointer;
    transition: all 0.3s ease; box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  @media(min-width: 768px) { .tf-news-card { flex-direction: row; } }
  
  .tf-news-card:hover { border-color: #B88655; transform: translateY(-4px); }
  
  .tf-card-img-wrap {
    width: 100%; aspect-ratio: 4/3; position: relative; overflow: hidden;
    background: #111; flex-shrink: 0;
  }
  @media(min-width: 768px) { .tf-card-img-wrap { width: 40%; aspect-ratio: auto; } }
  
  .tf-card-img-wrap img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease;
  }
  .tf-news-card:hover .tf-card-img-wrap img { transform: scale(1.05); }
  
  .tf-card-tag {
    position: absolute; top: 15px; left: 15px; background: #B88655; color: #fff;
    font-size: 11px; font-weight: 700; text-transform: uppercase; padding: 6px 14px;
    border-radius: 50px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); z-index: 2;
  }

  .tf-card-content { padding: 30px; display: flex; flex-direction: column; justify-content: center; width: 100%; }
  @media(min-width: 768px) { .tf-card-content { width: 60%; } }
  
  .tf-card-meta { display: flex; gap: 20px; font-size: 13px; color: #6b7280; font-weight: 600; margin-bottom: 16px; }
  .tf-card-meta span { display: flex; align-items: center; gap: 6px; }
  .tf-card-meta svg { width: 14px; height: 14px; }
  
  .tf-card-title {
    font-size: 24px; font-weight: 800; color: #fff; margin: 0 0 16px; line-height: 1.3;
    transition: color 0.3s;
  }
  .tf-news-card:hover .tf-card-title { color: #B88655; }
  
  .tf-card-excerpt { color: #ffffff; opacity: 0.8; font-size: 16px; line-height: 1.6; margin: 0 0 24px; flex-grow: 1; }
  
  .tf-card-more {
    font-size: 13px; font-weight: 700; text-transform: uppercase; color: #B88655;
    display: inline-flex; align-items: center; transition: transform 0.3s;
  }
  .tf-news-card:hover .tf-card-more { transform: translateX(8px); }
  .tf-card-more svg { width: 16px; height: 16px; margin-left: 6px; }

  /* === ПУСТОЙ СТАТУС & КНОПКА ЗАГРУЗКИ === */
  .tf-empty-state { text-align: center; padding: 80px 20px; background: #1f1f1f; border-radius: 20px; border: 1px solid #333; }
  .tf-empty-state p { color: #9ca3af; font-size: 18px; margin-bottom: 20px; }
  .tf-empty-reset { background: none; border: none; color: #B88655; font-weight: 700; text-transform: uppercase; cursor: pointer; text-decoration: underline; font-family: 'Montserrat'; font-size: 14px;}

  .tf-load-more {
    display: block; margin: 60px auto 0; background: transparent; border: 2px solid #B88655;
    color: #B88655; padding: 16px 40px; border-radius: 50px; font-size: 14px; font-weight: 700;
    text-transform: uppercase; cursor: pointer; transition: all 0.3s; font-family: 'Montserrat', sans-serif;
  }
  .tf-load-more:hover { background: #B88655; color: #fff; box-shadow: 0 5px 20px rgba(184,134,85,0.3); }

  /* === ЭКРАН 2: ДЕТАЛЬНАЯ СТАТЬЯ === */
  .tf-back-btn {
    display: inline-flex; align-items: center; gap: 8px; color: #9ca3af; font-weight: 600;
    background: none; border: none; cursor: pointer; padding: 0; font-size: 15px;
    margin-bottom: 40px; transition: color 0.3s; font-family: 'Montserrat', sans-serif;
  }
  .tf-back-btn:hover { color: #B88655; }
  
  .tf-article-header { text-align: center; margin-bottom: 40px; max-width: 800px; margin-left: auto; margin-right: auto;}
  .tf-article-meta-top { display: flex; justify-content: center; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 25px; color: #9ca3af; font-size: 14px; font-weight: 600;}
  .tf-article-tag { background: #222; border: 1px solid #444; color: #B88655; padding: 6px 16px; border-radius: 50px; display: flex; align-items: center; gap: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);}
  .tf-article-title { font-size: clamp(32px, 5vw, 48px); font-weight: 900; margin: 0; line-height: 1.2; color: #fff; }
  
  .tf-article-cover { width: 100%; aspect-ratio: 21/9; border-radius: 20px; overflow: hidden; margin-bottom: 50px; border: 1px solid #333; box-shadow: 0 20px 40px rgba(0,0,0,0.4); background: #111;}
  .tf-article-cover img { width: 100%; height: 100%; object-fit: cover; }

  /* Типографика статьи (SEO-оптимизировано) */
  .tf-prose { max-width: 800px; margin: 0 auto; color: #ffffff; opacity: 0.9; font-size: 18px; line-height: 1.9; }
  .tf-prose h2 { font-size: 30px; color: #fff; margin: 50px 0 25px; border-bottom: 1px solid #333; padding-bottom: 15px; font-weight: 800;}
  .tf-prose h3 { font-size: 24px; color: #fff; margin: 40px 0 20px; font-weight: 700;}
  .tf-prose p { margin-bottom: 25px; }
  .tf-prose .lead { font-size: 22px; font-weight: 500; color: #e5e7eb; opacity: 1; }
  .tf-prose a { color: #B88655; text-decoration: none; border-bottom: 1px solid #B88655; transition: opacity 0.3s; }
  .tf-prose a:hover { opacity: 0.7; }
  .tf-prose strong { color: #fff; font-weight: 700; opacity: 1;}
  .tf-prose ul { padding-left: 20px; margin-bottom: 30px; }
  .tf-prose li { margin-bottom: 12px; }
  .tf-prose blockquote { border-left: 4px solid #B88655; padding-left: 24px; font-style: italic; color: #9ca3af; margin: 40px 0; font-size: 20px;}

  /* Источник Дзен (Альтернатива Canonical для защиты от дублей) */
  .tf-dzen-source {
    max-width: 800px; margin: 60px auto 0; background: #1f1f1f; border: 1px solid #333;
    padding: 30px; border-radius: 16px; display: flex; flex-direction: column; gap: 20px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  @media(min-width: 640px) { .tf-dzen-source { flex-direction: row; justify-content: space-between; align-items: center; } }
  .tf-dzen-text strong { display: block; color: #fff; font-size: 18px; margin-bottom: 6px; font-weight: 800;}
  .tf-dzen-text span { color: #9ca3af; font-size: 15px; }
  .tf-dzen-btn {
    background: #B88655; color: #fff; text-decoration: none; padding: 14px 28px;
    border-radius: 8px; font-weight: 700; font-size: 14px; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 8px; transition: background 0.3s; text-align: center; justify-content: center;
    box-shadow: 0 5px 15px rgba(184,134,85,0.3);
  }
  .tf-dzen-btn:hover { background: #a07449; }

  /* Другие статьи */
  .tf-read-also { margin-top: 80px; border-top: 1px solid #333; padding-top: 50px; }
  .tf-read-also h3 { font-size: 28px; font-weight: 800; margin-bottom: 30px; color: #fff; }
  .tf-read-also-grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  @media(min-width: 640px) { .tf-read-also-grid { grid-template-columns: repeat(3, 1fr); } }
  .tf-mini-card { background: #222; border-radius: 16px; overflow: hidden; cursor: pointer; border: 1px solid transparent; transition: border 0.3s; display: flex; flex-direction: column; }
  .tf-mini-card:hover { border-color: #B88655; }
  .tf-mini-cover { width: 100%; aspect-ratio: 16/10; overflow: hidden; background: #111;}
  .tf-mini-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .tf-mini-card:hover .tf-mini-cover img { transform: scale(1.05); }
  .tf-mini-content { padding: 20px; display: flex; flex-direction: column; flex-grow: 1; justify-content: space-between;}
  .tf-mini-cat { color: #B88655; font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 10px; }
  .tf-mini-title { font-size: 16px; font-weight: 700; line-height: 1.4; color: #fff; margin: 0 0 15px;}
  .tf-mini-card:hover .tf-mini-title { color: #B88655; }
  .tf-mini-date { font-size: 13px; color: #6b7280; display: flex; align-items: center; gap: 6px; font-weight: 500;}
</style>

<div class="tf-blog-wrapper" id="tfBlogApp">
  <div class="tf-container">
    
    <!-- ЭКРАН 1: ЛЕНТА НОВОСТЕЙ -->
    <div id="tfViewList" class="tf-view is-active">
      <header class="tf-header">
        <h1>Блог <span>TRUEFORM</span></h1>
        <p>Полезные статьи о спортивном питании, ассортименте и бизнесе по франшизе. Официальные материалы из нашего Яндекс.Дзен.</p>
        
        <div class="tf-filters" id="tfFiltersContainer"></div>
      </header>

      <div class="tf-news-feed" id="tfNewsFeed">
        <!-- Loader показывается до скачивания JSON -->
      </div>
      
      <div id="tfEmptyState" class="tf-empty-state" style="display: none;">
        <p>В этой категории пока нет новых статей.</p>
        <button class="tf-empty-reset" onclick="tfBlog.setCategory('Все')">Сбросить фильтр</button>
      </div>

      <button id="tfLoadMoreBtn" class="tf-load-more" onclick="tfBlog.loadMore()" style="display: none;">Показать больше статей</button>
    </div>

    <!-- ЭКРАН 2: СТРАНИЦА СТАТЬИ -->
    <div id="tfViewArticle" class="tf-view">
      <button class="tf-back-btn" onclick="tfBlog.goToList()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Назад к новостям
      </button>

      <article>
        <header class="tf-article-header">
          <div class="tf-article-meta-top">
            <span class="tf-article-tag">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
              <span id="tfArtCategory">Категория</span>
            </span>
            <span style="display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              <span id="tfArtDate">Дата</span>
            </span>
            <span style="display: flex; align-items: center; gap: 6px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              <span id="tfArtReadTime">Время</span>
            </span>
          </div>
          <!-- SEO: Строго один H1 -->
          <h1 class="tf-article-title" id="tfArtTitle">Заголовок</h1>
        </header>

        <div class="tf-article-cover">
          <img id="tfArtCover" src="" alt="Обложка">
        </div>

        <div class="tf-prose" id="tfArtContent">
          <!-- Контент инжектится сюда -->
        </div>

        <div class="tf-dzen-source">
          <div class="tf-dzen-text">
            <strong>Понравилась статья?</strong>
            <span>Этот и другие материалы доступны в нашем официальном блоге.</span>
          </div>
          <a href="#" id="tfArtDzenLink" target="_blank" rel="nofollow noopener" class="tf-dzen-btn">
            Читать в Дзене 
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
          </a>
        </div>

        <div class="tf-read-also" id="tfReadAlsoBlock" style="display: none;">
          <h3>Другие материалы</h3>
          <div class="tf-read-also-grid" id="tfReadAlsoGrid"></div>
        </div>
      </article>
    </div>

  </div>
</div>

<!-- SEO: Динамический Schema.org -->
<script type="application/ld+json" id="tfSchemaScript">{}</script>

<script>
// ВАША РАБОЧАЯ ССЫЛКА НА GITHUB ACTIONS
const DATA_URL = 'https://raw.githubusercontent.com/nikitakorshikovuz-ui/trueform-blog-api/refs/heads/main/trueform_blog_data.json'; 

window.TRUEFORM_BLOG_DATA = [];

document.addEventListener('DOMContentLoaded', async () => {
  const feedContainer = document.getElementById('tfNewsFeed');
  if (feedContainer) {
    feedContainer.innerHTML = '<div style="text-align:center; padding: 50px; color: #B88655; font-weight: bold; font-size: 18px;">Синхронизация с Яндекс.Дзен...</div>';
  }

  try {
    // Получаем JSON с гитхаба (добавляем метку времени чтобы обойти жесткий кэш браузера)
    const response = await fetch(DATA_URL + '?t=' + new Date().getTime(), { cache: "no-store" });
    if (!response.ok) throw new Error("Network response was not ok");
    
    const data = await response.json();
    window.TRUEFORM_BLOG_DATA = data;
    
    // Запускаем рендер
    tfBlog.init();

  } catch (error) {
    console.error("Ошибка загрузки новостей:", error);
    if (feedContainer) {
      feedContainer.innerHTML = '<div style="text-align:center; padding: 50px; color: #ff4444; font-weight: bold;">Упс! Не удалось загрузить статьи. Попробуйте обновить страницу.</div>';
    }
  }
});

const tfBlog = (() => {
  const CATEGORIES = ['Все', 'ПП-рецепты', 'Похудение', 'Набор массы', 'Здоровье', 'Бизнес'];
  let currentCategory = 'Все';
  let displayedCount = 6;
  const STEP = 6;

  // DOM Элементы
  const elViewList = document.getElementById('tfViewList');
  const elViewArticle = document.getElementById('tfViewArticle');
  const elFilters = document.getElementById('tfFiltersContainer');
  const elNewsFeed = document.getElementById('tfNewsFeed');
  const elEmptyState = document.getElementById('tfEmptyState');
  const elLoadMoreBtn = document.getElementById('tfLoadMoreBtn');
  const elSchemaScript = document.getElementById('tfSchemaScript');

  // Утилита: формат даты
  const formatDate = (dateStr) => {
    return new Date(dateStr).toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' });
  };

  // SEO: Установка Canonical и Title
  const updateSEO = (article) => {
    document.title = article ? `${article.title} | Блог TRUEFORM` : 'Блог TRUEFORM | Статьи и Новости';
    
    let canonical = document.querySelector("link[rel='canonical']");
    if (!canonical) {
      canonical = document.createElement('link');
      canonical.setAttribute('rel', 'canonical');
      document.head.appendChild(canonical);
    }
    canonical.setAttribute('href', article 
      ? `https://franshiza-trueform.ru/blog/${article.slug}` 
      : 'https://franshiza-trueform.ru/blog'
    );

    const schemaData = article ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "mainEntityOfPage": { "@type": "WebPage", "@id": `https://franshiza-trueform.ru/blog/${article.slug}` },
      "headline": article.title,
      "image": article.cover,
      "datePublished": article.date,
      "author": { "@type": "Organization", "name": "TRUEFORM" }
    } : {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Блог TRUEFORM",
      "url": "https://franshiza-trueform.ru/blog"
    };
    elSchemaScript.innerHTML = JSON.stringify(schemaData);
  };

  // Рендер Фильтров
  const renderFilters = () => {
    elFilters.innerHTML = CATEGORIES.map(cat => `
      <button class="tf-filter-btn ${cat === currentCategory ? 'is-active' : ''}" onclick="tfBlog.setCategory('${cat}')">
        ${cat}
      </button>
    `).join('');
  };

  // Рендер Списка Новостей
  const renderFeed = () => {
    const data = window.TRUEFORM_BLOG_DATA;
    const filtered = currentCategory === 'Все' ? data : data.filter(a => a.category === currentCategory);
    
    if (filtered.length === 0) {
      elNewsFeed.innerHTML = '';
      elEmptyState.style.display = 'block';
      elLoadMoreBtn.style.display = 'none';
      return;
    }

    elEmptyState.style.display = 'none';
    const toShow = filtered.slice(0, displayedCount);

    elNewsFeed.innerHTML = toShow.map(news => `
      <article class="tf-news-card" onclick="tfBlog.openArticle('${news.slug}')">
        <div class="tf-card-img-wrap">
          <div class="tf-card-tag">${news.category}</div>
          <img src="${news.cover}" alt="${news.title}" loading="lazy">
        </div>
        <div class="tf-card-content">
          <div class="tf-card-meta">
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg> ${formatDate(news.date)}</span>
            <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg> ${news.readTime}</span>
          </div>
          <h2 class="tf-card-title">${news.title}</h2>
          <p class="tf-card-excerpt">${news.excerpt}</p>
          <div class="tf-card-more">
            Читать статью <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </div>
        </div>
      </article>
    `).join('');

    elLoadMoreBtn.style.display = filtered.length > displayedCount ? 'block' : 'none';
  };

  return {
    init: () => {
      renderFilters();
      renderFeed();
      updateSEO(null);
    },
    
    setCategory: (cat) => {
      currentCategory = cat;
      displayedCount = STEP;
      renderFilters();
      renderFeed();
    },

    loadMore: () => {
      displayedCount += STEP;
      renderFeed();
    },

    openArticle: (slug) => {
      const article = window.TRUEFORM_BLOG_DATA.find(a => a.slug === slug);
      if(!article) return;

      document.getElementById('tfArtCategory').textContent = article.category;
      document.getElementById('tfArtDate').textContent = formatDate(article.date);
      document.getElementById('tfArtReadTime').textContent = article.readTime;
      document.getElementById('tfArtTitle').textContent = article.title;
      document.getElementById('tfArtCover').src = article.cover;
      document.getElementById('tfArtCover').alt = article.title;
      document.getElementById('tfArtContent').innerHTML = article.content;
      document.getElementById('tfArtDzenLink').href = article.dzenUrl;

      // Читайте также
      const others = window.TRUEFORM_BLOG_DATA.filter(a => a.id !== article.id).slice(0, 3);
      const elReadAlsoGrid = document.getElementById('tfReadAlsoGrid');
      const elReadAlsoBlock = document.getElementById('tfReadAlsoBlock');
      
      if(others.length > 0) {
        elReadAlsoBlock.style.display = 'block';
        elReadAlsoGrid.innerHTML = others.map(news => `
          <div class="tf-mini-card" onclick="tfBlog.openArticle('${news.slug}')">
            <div class="tf-mini-cover"><img src="${news.cover}" alt=""></div>
            <div class="tf-mini-content">
              <div class="tf-mini-cat">${news.category}</div>
              <h4 class="tf-mini-title">${news.title}</h4>
              <div class="tf-mini-date">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                ${formatDate(news.date)}
              </div>
            </div>
          </div>
        `).join('');
      } else {
        elReadAlsoBlock.style.display = 'none';
      }

      elViewList.classList.remove('is-active');
      elViewArticle.classList.add('is-active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      updateSEO(article);
    },

    goToList: () => {
      elViewArticle.classList.remove('is-active');
      elViewList.classList.add('is-active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
      updateSEO(null);
    }
  };
})();
</script>
